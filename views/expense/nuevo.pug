extends ../layout.pug

block metadata
  title Gastos
  meta(name='description', content='Nuevo gasto')

block content
  h1 Nuevo gasto

  form(action='/expense/nuevo', method='post', novalidate)
    div
      label(for='monto') Monto
      input(type='number', name='monto', id='monto', min='0.01', step='0.01', required, value=values && values.monto ? values.monto : '')

    div
      label(for='titulo') Titulo
      input(type='text', name='titulo', id='titulo', required, maxlength='50', value=values && values.titulo ? values.titulo : '')

    div
      label(for='descripcion') Descripcion
      textarea(name='descripcion', id='descripcion', rows='3')= values && values.descripcion ? values.descripcion : ''

    div
      label(for='categoriaId') Categoria
      select(name='categoriaId', id='categoriaId', required)
        option(value='') Selecciona una categoria
        each c in categorias
          option(value=c.id, selected=values && Number(values.categoriaId) === c.id) #{c.title}

    div
      button(type='submit') Guardar gasto
      |  
      a(href='/expense') Volver