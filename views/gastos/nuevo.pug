extends ../layout.pug

block metadata
  title Gastos
  meta(name='description', content='Nuevo gasto')

block content
  h1 Complete los datos
  form(action="/gastos/nuevo", method="post", novalidate) 
    label(for="monto") Monto
      input(type="number", name="monto", id="monto", min="0", required)
    br
    label(for="titulo") Titulo
      input(type="text", name="titulo", id="titulo", required)
    br
    button(type="submit") Enviar