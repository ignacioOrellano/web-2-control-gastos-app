mixin item(path, name, active)
  li
    if active
      a(href=path class='active') #{name}
    else 
      a(href=path) #{name}

mixin nav
  nav
    ul
      +item('/', 'Home', currentPath == '/')
      +item('/expense', 'Gastos', currentPath.startsWith('/expense'))
      +item('/tag', 'Categorías', currentPath.startsWith('/tag'))
      if currentUser
        li.nav-user
          div.nav-user-profile
            span #{currentUser.firstName} #{currentUser.lastName}
            img(src='/icons/user-svgrepo-com.svg', alt='Usuario', width='22', height='22')